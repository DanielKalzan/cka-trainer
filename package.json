{
  "name": "learning-path",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,bridge -c blue,green \"next dev\" \"tsx watch server/index.ts\"",
    "dev:web": "next dev",
    "dev:bridge": "tsx watch server/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "test": "vitest run",
    "cluster:up": "bash scripts/cluster/up.sh",
    "cluster:down": "bash scripts/cluster/down.sh",
    "cluster:reset": "bash scripts/cluster/reset.sh"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^12.42.2",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.23.0",
    "next": "14.2.35",
    "node-pty": "^1.1.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
